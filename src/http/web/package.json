{
  "name": "swarm-web",
  "version": "0.1.0",
  "private": true,
  "description": "Web UI for dyson-swarm. Bundled into the Rust binary by build.rs.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
